# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# Database Configuration
DATABASE_URL=sqlite:///traffic_ai.db
# For PostgreSQL: postgresql://user:password@localhost:5432/traffic_ai

# API Configuration
API_PORT=5000
API_HOST=0.0.0.0

# Detection Configuration
HELMET_CONFIDENCE_THRESHOLD=0.6
SEATBELT_CONFIDENCE_THRESHOLD=0.6
VEHICLE_CONFIDENCE_THRESHOLD=0.5

# Signal Configuration
GREEN_LIGHT_DURATION=10
RED_LIGHT_DURATION=5
YELLOW_LIGHT_DURATION=2

# Video Source
VIDEO_SOURCE=0
FRAME_WIDTH=640
FRAME_HEIGHT=480
FRAME_SKIP=2
